# Copia para `.env` na tua máquina (nunca commits com segredos).
# O portfólio atual não precisa de base de dados; usa DATABASE_URL só quando
# tiveres persistência (ex.: mensagens de contacto, CMS, etc.).
#
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Mundo 3D. Por defeito off em produção; opt-in com ?world=1 ou botão no header.
# NEXT_PUBLIC_WORLD_3D=0
# Forçar 3D em produção (só após validação Fase 5):
# NEXT_PUBLIC_WORLD_3D=1
# Mobile: omitir = 3D permitido (perfil low). 0 = só desktop (>768px).
# NEXT_PUBLIC_WORLD_3D_MOBILE=0

# Mundo 3D — só `public/world/blender.glb` (modo simples)
# NEXT_PUBLIC_WORLD_SCENE=blender
# NEXT_PUBLIC_WORLD_3D=1
# NEXT_PUBLIC_WORLD_TONE_EXPOSURE=0.7
# NEXT_PUBLIC_WORLD_ENV_INTENSITY=0.4
# NEXT_PUBLIC_WORLD_AMBIENT_INTENSITY=0.25
# NEXT_PUBLIC_WORLD_DIR_LIGHT_1=0.45
# NEXT_PUBLIC_WORLD_GLB_ANIM=1
# NEXT_PUBLIC_WORLD_GLB_ANIM_MOBILE=0
